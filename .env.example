# BriefChain backend configuration
# Copy this file to `.env` in the project root and adjust values as needed.

# -----------------------------------------------------------------------------
# JWT configuration
# -----------------------------------------------------------------------------

JWT_SECRET_KEY=local-development-secret-key-do-not-use-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# -----------------------------------------------------------------------------
# Database URL used by both the application and Alembic migrations.
# Examples:
#   SQLite (default, local dev): sqlite:///./briefchain.db
#   PostgreSQL (async):          postgresql+asyncpg://user:password@localhost:5432/briefchain
DATABASE_URL=sqlite:///./briefchain.db

# -----------------------------------------------------------------------------
# Object storage
# -----------------------------------------------------------------------------

# Currently only "local" is supported.
OBJECT_STORAGE_TYPE=local

# Local directory where uploaded files are stored.
OBJECT_STORAGE_PATH=./.storage

# Base URL used when generating object URLs.
OBJECT_STORAGE_BASE_URL=/storage
