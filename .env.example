# BriefChain backend configuration
# Copy this file to `.env` in the project root and adjust values as needed.

# -----------------------------------------------------------------------------
# JWT configuration
# -----------------------------------------------------------------------------

JWT_SECRET_KEY=local-development-secret-key-do-not-use-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# -----------------------------------------------------------------------------
# Database URL used by both the application and Alembic migrations.
# Examples:
#   SQLite (default, local dev): sqlite:///./briefchain.db
#   PostgreSQL (async):          postgresql+asyncpg://user:password@localhost:5432/briefchain
DATABASE_URL=sqlite:///./briefchain.db

# -----------------------------------------------------------------------------
# Object storage
# -----------------------------------------------------------------------------

# Currently only "local" is supported.
OBJECT_STORAGE_TYPE=local

# Local directory where uploaded files are stored.
OBJECT_STORAGE_PATH=./.storage

# Base URL used when generating object URLs.
OBJECT_STORAGE_BASE_URL=/storage

# -----------------------------------------------------------------------------
# Arbiter review configuration
# -----------------------------------------------------------------------------

# LLM provider configuration (third-party OpenAI-compatible API).
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o
# LLM_API_KEY=sk-...

# Set to true to bypass LLM review and mark reviews as force_skipped.
SKIP_REVIEW=true

# Queue backend: "database" (default) or "redis" (future).
QUEUE_BACKEND=database

# Worker configuration.
WORKER_POLL_INTERVAL=2.0
WORKER_MAX_RETRIES=3
WORKER_HEALTH_CHECK_INTERVAL=60.0
WORKER_PROCESSING_TIMEOUT=300.0

# Default webhook URL for Arbiter review notifications.
# ARBITER_WEBHOOK_URL=https://my-app.com/webhooks/reviews

# Whether to spawn the Arbiter worker subprocess on application startup.
# Disable in test environments.
ARBITER_WORKER_SPAWN=true
