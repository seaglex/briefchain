# BriefChain Next.js frontend configuration
# Copy this file to `.env.local` (or `.env`) in this directory and adjust as needed.

# Server-side backend API URL used by Next.js API routes.
# Defaults to NEXT_PUBLIC_API_BASE_URL or http://localhost:8000.
API_BASE_URL=http://localhost:8000

# Public backend API URL exposed to the browser (must be prefixed with NEXT_PUBLIC_).
# Defaults to http://localhost:8000.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Comma-separated list of origins allowed to access Next.js dev resources (HMR).
# Required when accessing the dev server from a non-localhost IP.
# Example: ALLOWED_DEV_ORIGINS=192.168.1.100,192.168.1.101
ALLOWED_DEV_ORIGINS=192.168.1.100
